{
  "name": "vite-mix",
  "version": "0.8.1",
  "description": "Use Vite as Laravel Mix",
  "keywords": [
    "vite",
    "laravel",
    "mix",
    "laravel-mix",
    "webpack",
    "build-tool"
  ],
  "author": {
    "name": "Hugo Rodrigues",
    "url": "https://github.com/hugoboss17"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugoboss17/vite-mix.git"
  },
  "bugs": {
    "url": "https://github.com/hugoboss17/vite-mix/issues"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:pack": "node scripts/verify-pack.ts",
    "check:lockfile": "node scripts/check-lockfile-change.ts",
    "prepack": "npm run build && npm run verify:pack",
    "lint": "node -e \"console.log('add eslint if you want')\"",
    "prepare": "pre-commit install || true"
  },
  "dependencies": {},
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "sass": "^1.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  }
}
